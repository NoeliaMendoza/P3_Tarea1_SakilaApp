@model IEnumerable<SakilaApp.Models.Category>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.LastUpdate)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.LastUpdate)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.CategoryId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.CategoryId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.CategoryId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>

<nav class="mt-3" aria-label="Paginación">
    <ul class="pagination justify-content-center">
        @{ 
            int paginaActual = ViewBag.PaginaActual is int p ? p : 1;
            int totalPaginas = ViewBag.TotalPaginas is int tp ? tp : 1;
            int rango = 5;
            int inicio = Math.Max(1, paginaActual - rango);
            int fin = Math.Min(totalPaginas, paginaActual + rango);
        }

        <li class="page-item @(paginaActual == 1 ? "disabled" : "")">
            <a class="page-link" asp-action="Index" asp-route-pagina="1">&laquo;</a>
        </li>
        <li class="page-item @(paginaActual == 1 ? "disabled" : "")">
            <a class="page-link" asp-action="Index" asp-route-pagina="@(paginaActual - 1)">&lsaquo;</a>
        </li>

        @if (inicio > 1)
        {
            <li class="page-item disabled"><span class="page-link">…</span></li>
        }

        @for (int i = inicio; i <= fin; i++)
        {
            <li class="page-item @(i == paginaActual ? "active" : "")">
                <a class="page-link" asp-action="Index" asp-route-pagina="@i">@i</a>
            </li>
        }

        @if (fin < totalPaginas)
        {
            <li class="page-item disabled"><span class="page-link">…</span></li>
        }

        <li class="page-item @(paginaActual == totalPaginas ? "disabled" : "")">
            <a class="page-link" asp-action="Index" asp-route-pagina="@(paginaActual + 1)">&rsaquo;</a>
        </li>
        <li class="page-item @(paginaActual == totalPaginas ? "disabled" : "")">
            <a class="page-link" asp-action="Index" asp-route-pagina="@totalPaginas">&raquo;</a>
        </li>
    </ul>
    <p class="text-center text-muted small">Página @paginaActual de @totalPaginas</p>
</nav>
