@model IEnumerable<SakilaApp.Models.Actor>

@{
    ViewData["Title"] = "Actores";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Actores</h2>
        <a asp-action="Create" class="btn btn-outline-primary">+ Nuevo Actor</a>
    </div>

    <form asp-action="Index" method="get" class="mb-3">
        <div class="row g-2">
            <div class="col-md-5">
                <input type="text" name="buscar" value="@ViewBag.Buscar" class="form-control"
                       placeholder="Buscar por nombre o apellido" />
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-primary">Filtrar</button>
                <a asp-action="Index" class="btn btn-secondary">Limpiar</a>
            </div>
        </div>
    </form>

    <table class="table table-hover table-bordered">
        <thead>
            <tr class="table-light">
                <th>@Html.DisplayNameFor(model => model.FirstName)</th>
                <th>@Html.DisplayNameFor(model => model.LastName)</th>
                <th>@Html.DisplayNameFor(model => model.LastUpdate)</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@Html.DisplayFor(modelItem => item.FirstName)</td>
                    <td>@Html.DisplayFor(modelItem => item.LastName)</td>
                    <td>@Html.DisplayFor(modelItem => item.LastUpdate)</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.ActorId" class="btn btn-sm btn-outline-secondary">Editar</a>
                        <a asp-action="Details" asp-route-id="@item.ActorId" class="btn btn-sm btn-outline-secondary">Detalle</a>
                        <a asp-action="Delete" asp-route-id="@item.ActorId" class="btn btn-sm btn-outline-danger">Eliminar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <nav class="mt-3" aria-label="Paginación">
        <ul class="pagination justify-content-center">
            @{ 
                int paginaActual = ViewBag.PaginaActual is int p ? p : 1;
                int totalPaginas = ViewBag.TotalPaginas is int tp ? tp : 1;
                int rango = 5;
                int inicio = Math.Max(1, paginaActual - rango);
                int fin = Math.Min(totalPaginas, paginaActual + rango);
            }

            <li class="page-item @(paginaActual == 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-buscar="@ViewBag.Buscar" asp-route-pagina="1">&laquo;</a>
            </li>
            <li class="page-item @(paginaActual == 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-buscar="@ViewBag.Buscar" asp-route-pagina="@(paginaActual - 1)">&lsaquo;</a>
            </li>

            @if (inicio > 1)
            {
                <li class="page-item disabled"><span class="page-link">…</span></li>
            }

            @for (int i = inicio; i <= fin; i++)
            {
                <li class="page-item @(i == paginaActual ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-buscar="@ViewBag.Buscar" asp-route-pagina="@i">@i</a>
                </li>
            }

            @if (fin < totalPaginas)
            {
                <li class="page-item disabled"><span class="page-link">…</span></li>
            }

            <li class="page-item @(paginaActual == totalPaginas ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-buscar="@ViewBag.Buscar" asp-route-pagina="@(paginaActual + 1)">&rsaquo;</a>
            </li>
            <li class="page-item @(paginaActual == totalPaginas ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-buscar="@ViewBag.Buscar" asp-route-pagina="@totalPaginas">&raquo;</a>
            </li>
        </ul>
        <p class="text-center text-muted small">Página @paginaActual de @totalPaginas</p>
    </nav>
</div>
