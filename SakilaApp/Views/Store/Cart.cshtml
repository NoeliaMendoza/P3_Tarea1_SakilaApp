@model IEnumerable<SakilaApp.Models.Commerce.ShoppingCartItem>

@{
    ViewData["Title"] = "Carrito de compras";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Carrito de compras</h2>
        <a class="btn btn-outline-secondary" asp-action="Index">Seguir comprando</a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <table class="table table-hover table-bordered">
        <thead>
            <tr class="table-light">
                <th>Película</th>
                <th>Cantidad</th>
                <th>Precio</th>
                <th>Subtotal</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.FilmStock.Title</td>
                    <td>@item.Quantity</td>
                    <td>@item.FilmStock.UnitPrice.ToString("C")</td>
                    <td>@((item.Quantity * item.FilmStock.UnitPrice).ToString("C"))</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body d-flex align-items-center justify-content-between">
            <h4 class="mb-0">Total: <strong>@Model.Sum(i => i.Quantity * i.FilmStock.UnitPrice).ToString("C")</strong></h4>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-4">
            <form asp-action="Checkout" method="post">
                <button class="btn btn-primary w-100">Pagar con PayPhone</button>
            </form>
        </div>
        <div class="col-md-4">
            <form asp-action="Checkout" method="post">
                <input type="hidden" name="provider" value="PayPal" />
                <button class="btn btn-info w-100">Pagar con PayPal Sandbox</button>
            </form>
        </div>
        <div class="col-md-4">
            <form asp-action="CheckoutPayPalButton" method="post">
                <button class="btn btn-dark w-100">Pagar con botón PayPal / Tarjeta</button>
            </form>
        </div>
    </div>
</div>