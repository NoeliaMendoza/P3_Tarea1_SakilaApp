@model SakilaApp.Models.Film

@{
    ViewData["Title"] = "Detalle de Película";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Detalle de Película</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">← Volver</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3 fw-semibold">@Html.DisplayNameFor(model => model.Title)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Title)</dd>

                <dt class="col-sm-3 fw-semibold">@Html.DisplayNameFor(model => model.Description)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Description)</dd>

                <dt class="col-sm-3 fw-semibold">@Html.DisplayNameFor(model => model.ReleaseYear)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.ReleaseYear)</dd>

                <dt class="col-sm-3 fw-semibold">@Html.DisplayNameFor(model => model.RentalDuration)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.RentalDuration)</dd>

                <dt class="col-sm-3 fw-semibold">@Html.DisplayNameFor(model => model.RentalRate)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.RentalRate)</dd>

                <dt class="col-sm-3 fw-semibold">@Html.DisplayNameFor(model => model.Length)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Length)</dd>

                <dt class="col-sm-3 fw-semibold">@Html.DisplayNameFor(model => model.ReplacementCost)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.ReplacementCost)</dd>

                <dt class="col-sm-3 fw-semibold">@Html.DisplayNameFor(model => model.LastUpdate)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.LastUpdate)</dd>

                <dt class="col-sm-3 fw-semibold">@Html.DisplayNameFor(model => model.SpecialFeatures)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.SpecialFeatures)</dd>

                <dt class="col-sm-3 fw-semibold">@Html.DisplayNameFor(model => model.Language)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Language.LanguageId)</dd>

                <dt class="col-sm-3 fw-semibold">@Html.DisplayNameFor(model => model.OriginalLanguage)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.OriginalLanguage.LanguageId)</dd>
            </dl>

            <div class="mt-3">
                <a asp-action="Edit" asp-route-id="@Model?.FilmId" class="btn btn-outline-secondary">Editar</a>
            </div>
        </div>
    </div>
</div>
