@{
    ViewData["Title"] = "Panel de Administración";
}

<div class="container mt-4">
    <h2 class="mb-4">Panel de Administración</h2>
    <p class="text-muted">Solo los usuarios con rol <strong>Administrador</strong> pueden ver esta sección.</p>

    <div class="row row-cols-1 row-cols-md-3 g-4">
        <div class="col">
            <div class="card h-100 border-primary">
                <div class="card-body">
                    <h5 class="card-title">Actores</h5>
                    <a asp-controller="Actors" asp-action="Index" class="btn btn-sm btn-primary">Ir al módulo</a>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100 border-primary">
                <div class="card-body">
                    <h5 class="card-title">Películas</h5>
                    <a asp-controller="Films" asp-action="Index" class="btn btn-sm btn-primary">Ir al módulo</a>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100 border-primary">
                <div class="card-body">
                    <h5 class="card-title">Idiomas</h5>
                    <a asp-controller="Languages" asp-action="Index" class="btn btn-sm btn-primary">Ir al módulo</a>
                </div>
            </div>
        </div>
    </div>
</div>