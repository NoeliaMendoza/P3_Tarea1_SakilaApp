@model IEnumerable<SakilaApp.Models.Commerce.FilmStock>

@{
    ViewData["Title"] = "Inventario de películas";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Inventario de películas</h2>
        <a class="btn btn-outline-primary" asp-action="Inicializar">+ Inicializar desde Sakila</a>
    </div>

    <table class="table table-hover table-bordered">
        <thead>
            <tr class="table-light">
                <th>Película</th>
                <th>Precio</th>
                <th>Stock</th>
                <th>Agregar stock</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Title</td>
                    <td>$@item.UnitPrice.ToString("F2")</td>
                    <td>@item.Stock</td>
                    <td>
                        <form asp-action="AumentarStock" method="post" class="d-flex gap-2">
                            <input type="hidden" name="id" value="@item.FilmStockId" />
                            <input type="number" name="cantidad" value="1" min="1" class="form-control" style="width:90px" />
                            <button class="btn btn-success">Aumentar</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>